# Database (development / Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=booking_development

# Staging (Railway): set these in Railway dashboard for staging app
# RAILS_ENV=staging
# SECRET_KEY_BASE=<run: openssl rand -hex 64>
# Use internal DB link for app↔DB (recommended): Railway sets DATABASE_URL to postgres.railway.internal
# DATABASE_URL=postgresql://user:pass@postgres.railway.internal:5432/railway
# DATABASE_PUBLIC_URL=postgresql://user:pass@maglev.proxy.rlwy.net:36861/railway  (external, only for local→staging DB)
# POSTGRES_DB=railway
# Optional: DB_REAPING_FREQUENCY=30  (seconds; default 30 — clears stale connections when using internal link)

# Production: set DATABASE_URL in production host (e.g. Railway production Postgres)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_MASTER_KEY=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_32_chars
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_HOURS=168

# CORS (Railway: set FRONTEND_URL and/or CORS_ORIGINS to your deployed frontend URL(s))
FRONTEND_URL=http://localhost:3001
# CORS_ORIGINS=https://your-app.vercel.app,https://glow.up.railway.app

# Google OAuth (optional). Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {BACKEND_URL}/auth/google_oauth2/callback
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# BACKEND_URL=https://your-api.railway.app  (set when frontend proxies /api so OAuth redirect uses correct host)

# Redis (Sidekiq / Active Job). If unset, jobs run inline and no Redis is required (e.g. Railway without Redis plugin).
# Railway: add Redis plugin; REDIS_URL is often internal (e.g. redis://Redis.railway.internal:6379).
# If the API gets "Name does not resolve" when enqueueing jobs, set REDIS_PUBLIC_URL on the API service to the public Redis URL.
REDIS_URL=redis://localhost:6379/0
# REDIS_PUBLIC_URL=redis://default:pass@containers-us-west-xxx.railway.app:6379  (use when internal URL doesn't resolve from API)

# Sentry (error tracking). Backend does NOT report to Sentry unless SENTRY_DSN is set.
# Set this in production/staging (e.g. Railway env vars) to get errors in Sentry.
# Get DSN at https://sentry.io → Project → Client Keys (DSN).
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_RELEASE=git SHA or version (optional)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_DEBUG=true  (optional, to troubleshoot SDK)

# ============================================
# FILE STORAGE CONFIGURATION
# ============================================

# MinIO (S3-compatible) for Development
# Default credentials - change in production!
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET=glow-development

# Cloudinary for Production
# Sign up at https://cloudinary.com to get these credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: folder in storage.yml (default glow). Must match when building URLs.
# CLOUDINARY_FOLDER=glow

# AWS S3 (alternative for production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=glow-uploads

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
THROTTLE_LOGIN_LIMIT=5
THROTTLE_LOGIN_PERIOD=20

# Email (SendGrid SMTP)
# Get API key from SendGrid: Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# Default From address for transactional emails
MAILER_SENDER=contact@ollazen.com

# Discord (optional): post app events to a channel (e.g. new signups, new bookings)
# Create a webhook in Discord: Server Settings → Integrations → Webhooks → New Webhook, then copy the URL.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Internationalization
DEFAULT_LOCALE=en
