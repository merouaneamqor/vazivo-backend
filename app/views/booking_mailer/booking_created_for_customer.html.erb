<div style="font-family: sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <% if @booking.status_confirmed? %>
    <p>Your booking has been confirmed.</p>
  <% else %>
    <p>We've received your booking request.</p>
    <p>The business will confirm it shortly. You'll get an email once it's confirmed.</p>
  <% end %>
  <p><strong><%= @business_name %></strong> – <%= @service_name %></p>
  <p>Date: <%= @date %> at <%= @time %></p>
  <p>Reference: #<%= @short_booking_id %></p>
</div>
