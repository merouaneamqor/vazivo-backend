<div style="font-family: sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <% if @booking.status_confirmed? %>
    <p>Votre réservation a été confirmée.</p>
  <% else %>
    <p>Nous avons reçu votre demande de réservation.</p>
    <p>L'établissement la confirmera sous peu. Vous recevrez un email une fois confirmée.</p>
  <% end %>
  <p><strong><%= @business_name %></strong> – <%= @service_name %></p>
  <p>Date : <%= @date %> à <%= @time %></p>
  <p>Référence : #<%= @short_booking_id %></p>
</div>
