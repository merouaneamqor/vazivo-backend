<div style="font-family: sans-serif; max-width: 560px; margin: 0 auto; padding: 24px;">
  <h1 style="color: #111; font-size: 24px; margin-bottom: 16px;">Abonnement Premium confirmé</h1>
  <p style="color: #333; line-height: 1.6;">Bonjour <%= @user.name.presence || 'cher partenaire' %> !</p>
  <p style="color: #333; line-height: 1.6;">Votre abonnement premium pour <strong><%= @business_name %></strong> est actif.</p>
  <% if @expires_at.present? %>
    <p style="color: #333; line-height: 1.6;">Il est valable jusqu'au <%= @expires_at.strftime("%d %B %Y") %>.</p>
  <% end %>
  <p style="color: #333; line-height: 1.6;">— L'équipe Vazivo</p>
</div>
